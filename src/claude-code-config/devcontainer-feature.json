{
    "id": "claude-code-config",
    "version": "1.0.0",
    "name": "Claude Code Config",
    "description": "Shares Claude Code config across dev container rebuilds via a per-project named volume symlinked to ~/.claude, with the host's Claude credentials synced via postStartCommand.",
    "options": {},
    "containerEnv": {
        "CLAUDE_CONFIG_DIR": "/usr/local/share/claude-code-config"
    },
    "installsAfter": [
        "ghcr.io/devcontainers-extra/features/claude-code"
    ],
    "postStartCommand": "/usr/local/bin/claude-code-config-start.sh",
    "mounts": [
        {
            "source": "${localWorkspaceFolderBasename}-claude-code-config",
            "target": "/usr/local/share/claude-code-config",
            "type": "volume"
        },
        {
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.claude",
            "target": "/usr/local/share/claude-code-host-claude",
            "type": "bind"
        }
    ]
}
